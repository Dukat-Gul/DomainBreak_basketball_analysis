{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Basketball Analysis — Colab Training (Ball-only + Players Simplified)\n",
        "\n",
        "Runtime: GPU (L4 recommended). This notebook:\n",
        "- Creates two processed datasets:\n",
        "  - ball_only (single-class ‘ball’)\n",
        "  - players_simplified (classes: player, referee, rim)\n",
        "- Trains two YOLOv8 models with L4-friendly settings\n",
        "- Updates repo configs to use the new weights\n",
        "- Optional: quick validation\n",
        "\n",
        "Tip: Keep the repo synced in Drive at the project path defined below."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Install dependencies\n",
        "%pip install -q ultralytics==8.3.179 roboflow pyyaml tqdm"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Mount Google Drive\n",
        "from google.colab import drive, userdata\n",
        "drive.mount('/content/drive')\n",
        "\n",
        "# Set project path (update if needed)\n",
        "PROJECT_PATH = '/content/drive/MyDrive/basketball_analysis/basketball_analysis'\n",
        "%cd $PROJECT_PATH\n",
        "!ls -lah"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Download Dataset (Roboflow) — optional if already present\n",
        "If you've already downloaded your dataset to Drive, you can skip this.\n",
        "Avoid hardcoding API keys; set it from Colab secrets or env."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Optional: Download with Roboflow (edit workspace/project/version)\n",
        "import os\n",
        "rf_key = userdata.get('ROBOFLOW_API_KEY') or os.environ.get('ROBOFLOW_API_KEY')\n",
        "DATASET_PARENT = os.path.join(PROJECT_PATH, 'basketball-player-detection-2-1')\n",
        "\n",
        "if not os.path.exists(DATASET_PARENT):\n",
        "    from roboflow import Roboflow\n",
        "    assert rf_key, 'Set ROBOFLOW_API_KEY in Colab secrets or env.'\n",
        "    rf = Roboflow(api_key=rf_key)\n",
        "    project = rf.workspace('firstworkspace-riuxx').project('basketball-player-detection-2-68vvt')\n",
        "    version = project.version(1)\n",
        "    ds = version.download('yolov8', location=PROJECT_PATH)\n",
        "else:\n",
        "    print('Dataset already present at:', DATASET_PARENT)\n",
        "\n",
        "# Detect dataset root (folder created by Roboflow export)\n",
        "import glob\n",
        "candidates = []\n",
        "for p in glob.glob(os.path.join(PROJECT_PATH, '*')):\n",
        "    if os.path.isdir(p) and os.path.exists(os.path.join(p, 'data.yaml')):\n",
        "        candidates.append(p)\n",
        "assert candidates, 'No dataset with data.yaml found under PROJECT_PATH'\n",
        "DATASET_ROOT = sorted(candidates)[0]\n",
        "print('Using dataset root:', DATASET_ROOT)\n",
        "!sed -n '1,120p' "$DATASET_ROOT/data.yaml""
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Build Processed Datasets\n",
        "- ball_only: keep only class ‘ball’ lines in labels\n",
        "- players_simplified: merge all classes containing ‘player’ → ‘player’; keep ‘referee’, ‘rim’; drop others\n",
        "Uses symlinks for images to save space; copies or creates new labels."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import os, shutil, yaml, glob\n",
        "from tqdm import tqdm\n",
        "\n",
        "with open(os.path.join(DATASET_ROOT, 'data.yaml'), 'r') as f:\n",
        "    data_cfg = yaml.safe_load(f)\n",
        "names = data_cfg.get('names')\n",
        "assert isinstance(names, (list, dict)), 'Unexpected names format in data.yaml'\n",
        "if isinstance(names, dict):\n",
        "    # convert to list ordered by index\n",
        "    names_list = [names[k] for k in sorted(names.keys())]\n",
        "else:\n",
        "    names_list = names\n",
        "name_to_idx = {n: i for i, n in enumerate(names_list)}\n",
        "print('Classes:', names_list)\n",
        "\n",
        "# Identify indices\n",
        "ball_idx = None\n",
        "for i, n in enumerate(names_list):\n",
        "    if n.lower() == 'ball':\n",
        "        ball_idx = i\n",
        "        break\n",
        "assert ball_idx is not None, 'ball class not found'\n",
        "player_like = [i for i, n in enumerate(names_list) if 'player' in n.lower()]\n",
        "ref_idx = next((i for i, n in enumerate(names_list) if n.lower() == 'referee'), None)\n",
        "rim_idx = next((i for i, n in enumerate(names_list) if n.lower() == 'rim'), None)\n",
        "\n",
        "PROCESSED_ROOT = os.path.join(PROJECT_PATH, 'processed_datasets')\n",
        "os.makedirs(PROCESSED_ROOT, exist_ok=True)\n",
        "\n",
        "def ensure_dirs(root):\n",
        "    for split in ['train', 'valid', 'test']:\n",
        "        for sub in ['images', 'labels']:\n",
        "            os.makedirs(os.path.join(root, split, sub), exist_ok=True)\n",
        "\n",
        "def symlink_or_copy(src, dst):\n",
        "    if os.path.exists(dst):\n",
        "        return\n",
        "    try:\n",
        "        os.symlink(src, dst)\n",
        "    except Exception:\n",
        "        shutil.copy2(src, dst)\n",
        "\n",
        "def list_images(split_root):\n",
        "    img_dir = os.path.join(split_root, 'images')\n",
        "    return sorted(glob.glob(os.path.join(img_dir, '*')))\n",
        "\n",
        "def corresponding_label_path(img_path, base_root):\n",
        "    # replace .../images/xxx.jpg -> .../labels/xxx.txt\n",
        "    rel = os.path.relpath(img_path, base_root)\n",
        "    parts = rel.split(os.sep)\n",
        "    parts[1] = 'labels'  # split/images -> split/labels\n",
        "    lbl = os.path.splitext(os.sep.join(parts))[0] + '.txt'\n",
        "    return os.path.join(base_root, lbl)\n",
        "\n",
        "# Build ball_only\n",
        "ball_root = os.path.join(PROCESSED_ROOT, 'ball_only')\n",
        "ensure_dirs(ball_root)\n",
        "for split in ['train', 'valid', 'test']:\n",
        "    src_split = os.path.join(DATASET_ROOT, split)\n",
        "    dst_split = os.path.join(ball_root, split)\n",
        "    imgs = list_images(src_split)\n",
        "    for img in tqdm(imgs, desc=f'ball_only {split}'):\n",
        "        # link/copy image\n",
        "        dst_img = os.path.join(dst_split, 'images', os.path.basename(img))\n",
        "        symlink_or_copy(img, dst_img)\n",
        "        # filter label\n",
        "        src_lbl = corresponding_label_path(img, DATASET_ROOT)\n",
        "        dst_lbl = os.path.join(dst_split, 'labels', os.path.splitext(os.path.basename(img))[0] + '.txt')\n",
        "        lines = []\n",
        "        if os.path.exists(src_lbl):\n",
        "            with open(src_lbl, 'r') as f:\n",
        "                for ln in f:\n",
        "                    ln = ln.strip()\n",
        "                    if not ln:\n",
        "                        continue\n",
        "                    cid = int(ln.split()[0])\n",
        "                    if cid == ball_idx:\n",
        "                        # rewrite class id to 0\n",
        "                        rest = ' '.join(ln.split()[1:])\n",
        "                        lines.append('0 ' + rest)\n",
        "        with open(dst_lbl, 'w') as f:\n",
        "            f.write('\n'.join(lines))\n",
        "\n",
        "# Save ball_only yaml\n",
        "ball_yaml = os.path.join(PROCESSED_ROOT, 'ball_only.yaml')\n",
        "with open(ball_yaml, 'w') as f:\n",
        "    yaml.safe_dump({\n",
        "        'path': ball_root,\n",
        "        'train': 'train/images',\n",
        "        'val': 'valid/images',\n",
        "        'test': 'test/images',\n",
        "        'nc': 1,\n",
        "        'names': ['ball']\n",
        "    }, f)\n",
        "print('Saved', ball_yaml)\n",
        "\n",
        "# Build players_simplified\n",
        "assert ref_idx is not None and rim_idx is not None, 'referee or rim class not found'\n",
        "players_root = os.path.join(PROCESSED_ROOT, 'players_simplified')\n",
        "ensure_dirs(players_root)\n",
        "def map_player_label(cid):\n",
        "    if cid in player_like:\n",
        "        return 0  # player\n",
        "    if cid == ref_idx:\n",
        "        return 1  # referee\n",
        "    if cid == rim_idx:\n",
        "        return 2  # rim\n",
        "    return None\n",
        "for split in ['train', 'valid', 'test']:\n",
        "    src_split = os.path.join(DATASET_ROOT, split)\n",
        "    dst_split = os.path.join(players_root, split)\n",
        "    imgs = list_images(src_split)\n",
        "    for img in tqdm(imgs, desc=f'players_simplified {split}'):\n",
        "        dst_img = os.path.join(dst_split, 'images', os.path.basename(img))\n",
        "        symlink_or_copy(img, dst_img)\n",
        "        src_lbl = corresponding_label_path(img, DATASET_ROOT)\n",
        "        dst_lbl = os.path.join(dst_split, 'labels', os.path.splitext(os.path.basename(img))[0] + '.txt')\n",
        "        lines = []\n",
        "        if os.path.exists(src_lbl):\n",
        "            with open(src_lbl, 'r') as f:\n",
        "                for ln in f:\n",
        "                    ln = ln.strip()\n",
        "                    if not ln:\n",
        "                        continue\n",
        "                    parts = ln.split()\n",
        "                    cid = int(parts[0])\n",
        "                    mc = map_player_label(cid)\n",
        "                    if mc is None:\n",
        "                        continue\n",
        "                    parts[0] = str(mc)\n",
        "                    lines.append(' '.join(parts))\n",
        "        with open(dst_lbl, 'w') as f:\n",
        "            f.write('\n'.join(lines))\n",
        "\n",
        "players_yaml = os.path.join(PROCESSED_ROOT, 'players_simplified.yaml')\n",
        "with open(players_yaml, 'w') as f:\n",
        "    yaml.safe_dump({\n",
        "        'path': players_root,\n",
        "        'train': 'train/images',\n",
        "        'val': 'valid/images',\n",
        "        'test': 'test/images',\n",
        "        'nc': 3,\n",
        "        'names': ['player','referee','rim']\n",
        "    }, f)\n",
        "print('Saved', players_yaml)\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Train — Ball-only @1280 (YOLOv8m)\n",
        "L4-friendly: auto-batch with gradient accumulation to keep effective batch ~8.\n",
        "Augment tuned to preserve orange/shape cues."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from ultralytics import YOLO\n",
        "ball_model = YOLO('yolov8m.pt')\n",
        "ball_results = ball_model.train(\n",
        "    data=ball_yaml,\n",
        "    imgsz=1280,\n",
        "    batch=-1,            # auto\n",
        "    accumulate=4,        # effective batch ~8 if auto picks 2\n",
        "    epochs=180,\n",
        "    patience=50,\n",
        "    multi_scale=True,\n",
        "    rect=True,\n",
        "    mosaic=1.0,\n",
        "    close_mosaic=20,\n",
        "    hsv_h=0.015, hsv_s=0.5, hsv_v=0.3,\n",
        "    translate=0.05, scale=0.4,\n",
        "    erasing=0.0, mixup=0.0, copy_paste=0.0,\n",
        "    optimizer='auto',\n",
        "    deterministic=True,\n",
        "    name='ball_1280_m', project='runs/detect'\n",
        ")\n",
        "print('Ball run dir:', ball_results.save_dir)\n",
        "BALL_BEST = os.path.join(ball_results.save_dir, 'weights', 'best.pt')\n",
        "print('BALL_BEST:', BALL_BEST)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Validate — Ball-only"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "ball_model = YOLO(BALL_BEST)\n",
        "val_res = ball_model.val(data=ball_yaml, imgsz=1280)\n",
        "print(val_res.results_dict)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Train — Players Simplified @960 (YOLOv8m)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "players_model = YOLO('yolov8m.pt')\n",
        "players_results = players_model.train(\n",
        "    data=players_yaml,\n",
        "    imgsz=960,\n",
        "    batch=-1,\n",
        "    accumulate=4,\n",
        "    epochs=140,\n",
        "    patience=40,\n",
        "    multi_scale=True,\n",
        "    rect=True,\n",
        "    mosaic=1.0, close_mosaic=20,\n",
        "    optimizer='auto',\n",
        "    deterministic=True,\n",
        "    name='players_simplified_960_m', project='runs/detect'\n",
        ")\n",
        "print('Players run dir:', players_results.save_dir)\n",
        "PLAYERS_BEST = os.path.join(players_results.save_dir, 'weights', 'best.pt')\n",
        "print('PLAYERS_BEST:', PLAYERS_BEST)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Update repo configs to use new weights"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Save copies into models/ and update configs/configs.py\n",
        "MODELS_DIR = os.path.join(PROJECT_PATH, 'models')\n",
        "os.makedirs(MODELS_DIR, exist_ok=True)\n",
        "BALL_DST = os.path.join(MODELS_DIR, 'ball_best.pt')\n",
        "PLAYERS_DST = os.path.join(MODELS_DIR, 'players_best.pt')\n",
        "shutil.copy2(BALL_BEST, BALL_DST)\n",
        "shutil.copy2(PLAYERS_BEST, PLAYERS_DST)\n",
        "\n",
        "cfg_path = os.path.join(PROJECT_PATH, 'configs', 'configs.py')\n",
        "with open(cfg_path, 'r') as f:\n",
        "    cfg_txt = f.read()\n",
        "cfg_txt = cfg_txt.replace("BALL_DETECTOR_PATH = 'models/lastVersionModel.pt'", f"BALL_DETECTOR_PATH = 'models/ball_best.pt'")\n",
        "cfg_txt = cfg_txt.replace("PLAYER_DETECTOR_PATH = 'models/lastVersionModel.pt'", f"PLAYER_DETECTOR_PATH = 'models/players_best.pt'")\n",
        "with open(cfg_path, 'w') as f:\n",
        "    f.write(cfg_txt)\n",
        "print('Updated configs/configs.py')\n",
        "!sed -n '1,120p' configs/configs.py"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Optional: Quick pipeline evaluation (fast-dev)\n",
